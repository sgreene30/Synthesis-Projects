  20:../../../../../DaisyExamples/DaisySP//Source/Control/adsr.h **** - ATTACK  = First segment of envelope where phase moves from 0 to 1
  21:../../../../../DaisyExamples/DaisySP//Source/Control/adsr.h **** - DECAY   = Second segment of envelope where phase moves from 1 to SUSTAIN value
  22:../../../../../DaisyExamples/DaisySP//Source/Control/adsr.h **** - RELEASE =     Fourth segment of envelop where phase moves from SUSTAIN to 0
  23:../../../../../DaisyExamples/DaisySP//Source/Control/adsr.h **** */
  24:../../../../../DaisyExamples/DaisySP//Source/Control/adsr.h **** enum
  25:../../../../../DaisyExamples/DaisySP//Source/Control/adsr.h **** {
