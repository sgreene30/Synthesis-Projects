 178:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 179:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* FIR Latency is always 0, but API is unified with FFT and fast convolution */
 180:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     static constexpr size_t GetLatency() { return 0; }
 181:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 182:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Process one sample at a time */
 183:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     float Process(float in)
 184:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     {
 185:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(size_ > 0u);
 186:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         /* Feed data into the buffer */
 187:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         state_[size_ - 1u] = in;
 188:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 189:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         /* Convolution loop */
 190:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         float acc(0);
 191:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         for(size_t i = 0; i < size_ - 1; i++)
 192:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         {
 193:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             acc += state_[i] * coefs_[i];
 194:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             /** Shift the state simulatenously 
 195:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****              * (note: better solutions are available) 
 196:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****              */
 197:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             state_[i] = state_[1 + i];
 198:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         }
 199:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         acc += in * coefs_[size_ - 1u];
 200:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 201:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         return acc;
 202:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     }
 203:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 204:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Process a block of data */
 205:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     void ProcessBlock(const float* pSrc, float* pDst, size_t block)
 206:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     {
 207:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         /* be sure to run debug version from time to time */
 208:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(block <= FIRMem::MaxBlock());
 209:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(size_ > 0u);
 210:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(nullptr != pSrc);
 211:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(nullptr != pDst);
 212:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 213:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         /* Process the block of data */
 214:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         for(size_t j = 0; j < block; j++)
 215:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         {
 216:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             /* Feed data into the buffer */
 217:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             state_[size_ - 1u + j] = pSrc[j];
 218:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 219:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             /* Convolution loop */
 220:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             float acc = 0.0f;
 221:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             for(size_t i = 0; i < size_; i++)
 222:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             {
 223:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****                 acc += state_[j + i] * coefs_[i];
 224:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             }
 225:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 226:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             /* Write output */
 227:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             pDst[j] = acc;
 228:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         }
 229:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 230:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         /* Copy data tail for the next block */
 231:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         for(size_t i = 0; i < size_ - 1u; i++)
 232:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         {
ARM GAS  C:\Users\samue\AppData\Local\Temp\ccJVcVgn.s 			page 13


 233:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             state_[i] = state_[block + i];
