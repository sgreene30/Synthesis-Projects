 158:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** /** Generic FIR implementation is always available
 159:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * \param max_size - maximal filter length
 160:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * \param max_block - maximal block size for ProcessBlock()
 161:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * if both parameters are 0 (via FIRFILTER_USER_MEMORY macro)
 162:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * Assumes the user will provide own memory buffers
 163:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * via SetIR() and SetStateBuffer() functions
 164:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * Otherwise statically allocates the necessary buffers itself
 165:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  */
 166:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** template <size_t max_size, size_t max_block>
 167:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** class FIRFilterImplGeneric : public FIRMemory<max_size, max_block>
 168:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** {
 169:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****   private:
 170:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     using FIRMem = FIRMemory<max_size, max_block>; // just a shorthand
 171:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 172:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****   public:
 173:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Default constructor */
