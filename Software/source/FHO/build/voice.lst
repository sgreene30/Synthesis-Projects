 145:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** /** one pole lpf
 146:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** out is passed by reference, and must be retained between
 147:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** calls to properly filter the signal
 148:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** coeff can be calculated:
 149:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** coeff = 1.0 / (time * sample_rate) ; where time is in seconds
 150:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** */
 151:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** inline void fonepole(float &out, float in, float coeff)
 152:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** {
 153:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****     out += coeff * (in - out);
 154:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** }
 155:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** 
 156:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** /** Curves to use with the fmap function */
 157:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** enum class Mapping
 158:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** {
 159:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****     LINEAR,
 160:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****     EXP,
 161:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****     LOG,
 162:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** };
 163:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** 
 164:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** /** Maps a float between a specified range, using a specified curve.
 165:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *
 166:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *  \param in a value between 0 to 1 that will be mapped to the new range.
 167:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *  \param min the new minimum value
 168:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *  \param max the new maxmimum value
 169:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *  \param curve a Mapping Value to adjust the response curve of the transformation
ARM GAS  C:\Users\samue\AppData\Local\Temp\ccJVcVgn.s 			page 26


 170:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *               defaults to Linear. @see Mapping
 171:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *
 172:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *  When using the log curve min and max, must be greater than zero.
 173:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *
 174:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****  *  \retval returns the transformed float within the new range.
 175:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** */
 176:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** inline float
 177:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** fmap(float in, float min, float max, Mapping curve = Mapping::LINEAR)
 178:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** {
 179:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****     switch(curve)
 180:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****     {
 181:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****         case Mapping::EXP:
 182:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****             return fclamp(min + (in * in) * (max - min), min, max);
 183:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****         case Mapping::LOG:
 184:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****         {
 185:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****             const float a = 1.f / log10f(max / min);
 186:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****             return fclamp(min * powf(10, in / a), min, max);
 187:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****         }
 188:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****         case Mapping::LINEAR:
 189:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****         default: return fclamp(min + in * (max - min), min, max);
