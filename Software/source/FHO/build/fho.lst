  28:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** {
  29:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** /* use this as a template parameter to indicate user-provided memory storage */
  30:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** #define FIRFILTER_USER_MEMORY 0, 0
  31:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
  32:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** /** Helper class that defines the memory model - internal or user-provided 
  33:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * \param max_size - maximal filter length
  34:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * \param max_block - maximal length of the block processing
  35:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * if both parameters are 0, does NOT allocate any memory and instead
  36:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * requires user-provided memory blocks to be passed as parameters.
  37:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  *
  38:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  * Not intended to be used directly, so constructor is not exposed
  39:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****  */
  40:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** template <size_t max_size, size_t max_block>
  41:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** struct FIRMemory
  42:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** {
  43:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Public part of the API to be passed through to the FIR users */
  44:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****   public:
  45:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Reset the internal filter state (but not the coefficients) */
  46:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     void Reset() { memset(state_, 0, state_size_ * sizeof(state_[0])); }
  47:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
  48:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
  49:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****   protected:
  50:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     FIRMemory() : state_{0}, coefs_{0}, size_(0) {}
  51:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
  52:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Expression for the maximum block size */
  53:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     static constexpr size_t MaxBlock() { return max_block; }
  54:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
  55:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /** Configure the filter coefficients
  56:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \param coefs - pointer to coefficients (tail-first order)
  57:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \param size - number of coefficients pointed by coefs (filter length)
  58:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \param reverse - flag to perform reversing of the filter
  59:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \return true if all conditions are met and the filter is configured
  60:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      */
  61:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     bool SetCoefs(const float coefs[], size_t size, bool reverse)
  62:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     {
  63:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         /* truncate silently */
  64:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         size_ = DSY_MIN(size, max_size);
  65:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
  66:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         if(reverse)
  67:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         {
  68:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             /* reverse the IR */
  69:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             for(size_t i = 0; i < size_; i++)
  70:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             {
  71:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****                 /* start from size, not size_! */
  72:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****                 coefs_[i] = coefs[size - 1u - i];
  73:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             }
  74:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         }
  75:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         else
  76:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         {
  77:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             /* just copy as is */
  78:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             memcpy(coefs_, coefs, size_ * sizeof(coefs[0]));
  79:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         }
  80:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
  81:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         return true;
  82:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     }
  83:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
  84:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     static constexpr size_t state_size_ = max_size + max_block - 1u;
ARM GAS  C:\Users\samue\AppData\Local\Temp\ccT7sp1U.s 			page 20


  85:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     float                   state_[state_size_]; /*< Internal state buffer */
  86:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     float                   coefs_[max_size];    /*< Filter coefficients */
  87:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     size_t                  size_; /*< Active filter length (<= max_size) */
  88:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** };
