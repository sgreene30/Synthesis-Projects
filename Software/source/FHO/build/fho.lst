  90:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** /* Specialization for user-provided memory */
  91:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** template <>
  92:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** struct FIRMemory<FIRFILTER_USER_MEMORY>
  93:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** {
  94:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Public part of the API to be passed through to the FIRFilter user */
  95:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****   public:
  96:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /** Set user-provided state buffer
  97:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \param state - pointer to the allocated memory block
  98:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \param length - length of the provided memory block (in elements)
  99:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * The length should be determined as follows 
 100:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * length >= max_filter_size + max_processing_block - 1
 101:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      */
 102:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     void SetStateBuffer(float state[], size_t length)
 103:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     {
 104:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         state_      = state;
 105:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         state_size_ = length;
 106:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     }
 107:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Reset the internal filter state (but not the coefficients) */
 108:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     void Reset()
 109:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     {
 110:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(nullptr != state_);
 111:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(0 != state_size_);
 112:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         if(nullptr != state_)
 113:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         {
 114:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             memset(state_, 0, state_size_ * sizeof(state_[0]));
 115:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         }
 116:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     }
 117:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 118:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****   protected:
 119:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     FIRMemory() : state_(nullptr), coefs_(nullptr), size_(0), state_size_(0) {}
 120:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 121:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /* Expression for the maximum processing block size currently supported */
 122:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     size_t MaxBlock() const
 123:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     {
 124:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         return state_size_ + 1u > size_ ? state_size_ + 1u - size_ : 0;
 125:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     }
 126:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 127:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     /** Configure the filter coefficients
 128:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \param coefs - pointer to coefficients (tail-first order)
 129:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \param size - number of coefficients pointed by coefs (filter length)
 130:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \param reverse - flag to perform reversing of the filter
 131:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      * \return true if all conditions are met and the filter is configured
 132:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****      */
 133:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     bool SetCoefs(const float coefs[], size_t size, bool reverse)
 134:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****     {
 135:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         /* reversing of external IR is not supported*/
 136:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(false == reverse);
 137:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         assert(nullptr != coefs || 0 == size);
 138:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h **** 
 139:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         if(false == reverse && (nullptr != coefs || 0 == size))
 140:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****         {
 141:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             coefs_ = coefs;
ARM GAS  C:\Users\samue\AppData\Local\Temp\ccT7sp1U.s 			page 21


 142:../../../../DaisyExamples/DaisySP//Source/Filters/fir.h ****             size_  = size;
