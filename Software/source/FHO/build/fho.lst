   7:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h **** {
   8:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h **** /** @brief CPU load metering
   9:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  *  @author jelliesen
  10:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  *  @addtogroup utility
  11:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  * 
  12:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  *  To measure the CPU load of your audio processing, create a CpuLoadMeter
  13:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  *  and initialize it with your block size and sample rate.
ARM GAS  C:\Users\samue\AppData\Local\Temp\ccT7sp1U.s 			page 13


  14:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  *  Then at the beginning of the audio callback, call `OnBlockStart()`, 
  15:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  *  and at the end of the audio callback, call `OnBlockEnd()`.
  16:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  *  You can then read out the minimum, maximum and average CPU load.
  17:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****  */
  18:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h **** class CpuLoadMeter
  19:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h **** {
  20:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****   public:
  21:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****     CpuLoadMeter(){};
  22:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h **** 
  23:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****     /** Initializes the CpuLoadMeter for a particular sample rate and block size.
  24:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****      *  @param sampleRateInHz           The sample rate in Hz
  25:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****      *  @param blockSizeInSamples       The block size in samples
  26:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****      *  @param smoothingFilterCutoffHz  The cutoff frequency of the smoothing filter that's used to
  27:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****      *                                  create the average CPU load reading.
  28:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****      */
  29:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****     void Init(float sampleRateInHz,
  30:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****               int   blockSizeInSamples,
  31:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****               float smoothingFilterCutoffHz = 1.0f)
  32:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****     {
  33:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         const auto secPerBlock = float(blockSizeInSamples) / sampleRateInHz;
  34:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         const auto ticksPerS   = float(System::GetTickFreq());
  35:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         ticksPerBlockInv_      = 1.0f / (ticksPerS * secPerBlock);
  36:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h **** 
  37:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         // update filter coefficient for smoothing filter (1pole lowpass)
  38:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         const auto blockRateInHz = sampleRateInHz / float(blockSizeInSamples);
  39:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         const auto cutoffNormalized
  40:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****             = smoothingFilterCutoffHz * 2.0f * 3.141592653f / blockRateInHz;
  41:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         // according to
  42:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         // https://en.wikipedia.org/wiki/Low-pass_filter#Simple_infinite_impulse_response_filter
  43:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         smoothingConstant_ = cutoffNormalized / (cutoffNormalized + 1.0f);
  44:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h **** 
  45:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****         Reset();
  46:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****     }
  47:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h **** 
  48:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****     /** Call this at the beginning of your audio callback */
  49:../../../../DaisyExamples/libDaisy//src/util/CpuLoadMeter.h ****     void OnBlockStart() { currentBlockStartTicks_ = System::GetTick(); }
