  85:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** inline float fastroot(float f, int n)
  86:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** {
  87:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****     long *lp, l;
