 144:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** 
 145:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** /** one pole lpf
 146:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** out is passed by reference, and must be retained between
 147:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** calls to properly filter the signal
 148:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** coeff can be calculated:
 149:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** coeff = 1.0 / (time * sample_rate) ; where time is in seconds
 150:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** */
 151:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** inline void fonepole(float &out, float in, float coeff)
 152:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** {
 153:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h ****     out += coeff * (in - out);
 154:../../../../DaisyExamples/DaisySP//Source/Utility/dsp.h **** }
